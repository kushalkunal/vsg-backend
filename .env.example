# Required — Supabase PgBouncer pooler (transaction mode)
DATABASE_URL=jdbc:postgresql://aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?prepareThreshold=0&sslmode=require
DATABASE_USERNAME=postgres.qkeftruooargdavvqrxa
DATABASE_PASSWORD=your-supabase-db-password

# Optional: direct connection for Flyway migrations (avoids pooler limits)
# Get from Supabase → Project Settings → Database → URI (port 5432)
# FLYWAY_URL=jdbc:postgresql://db.qkeftruooargdavvqrxa.supabase.co:5432/postgres?sslmode=require

# JWT — use a random 64+ char string in production
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-256-bits-long
JWT_EXPIRATION_MS=86400000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Docker image name (for docker-compose)
DOCKER_IMAGE=yourdockerhubuser/vsg-backend:latest
